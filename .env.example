# Copy to .env and adjust for local development (optional; docker-compose sets these for containers).

# Use port 5433 if you follow docker-compose host mapping (5433:5432).
DATABASE_URL=postgresql://worklog:worklog@localhost:5433/worklog
PAYOUT_SIMULATE_FAILURE=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:80

# When true, POST /generate-remittances marks remittances failed and does not settle time entries.
# Useful for demonstrating retry-friendly behavior.
