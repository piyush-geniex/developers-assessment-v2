POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=assessment
# Host port when running Postgres via docker compose (default 5433 avoids local 5432 conflicts)
POSTGRES_PORT=5433
BACKEND_PORT=8000

# Optional: override when running the API outside Docker
# DATABASE_URL=postgresql+psycopg://appuser:apppass@localhost:5433/assessment

# Optional: path to seed JSON inside the backend container (compose sets this)
# SEED_JSON_PATH=/seed/worklogs.json
