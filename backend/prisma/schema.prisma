generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model worklog {
  id             Int         @id @default(autoincrement())
  external_id    String      @unique
  user_id        String
  user_name      String
  task_name      String
  hourly_rate    Decimal     @db.Decimal(10, 2)
  segment_ids    Json        @default("[]")
  adjustment_ids Json        @default("[]")
  status         String      @default("UNREMITTED")
  remittance_id  Int?
  created_at     DateTime    @default(now()) @db.Timestamptz
  remittance     remittance? @relation(fields: [remittance_id], references: [id])
  records        record[]

  @@index([user_id])
  @@index([remittance_id])
  @@index([status])
}

model record {
  id            Int         @id @default(autoincrement())
  type          String      // 'segment' | 'adjustment'
  parent_id     Int
  payload       Json
  start_time    DateTime?   @db.Timestamptz
  end_time      DateTime?   @db.Timestamptz
  seg_status    String?
  applied_at    DateTime?   @db.Timestamptz
  remittance_id Int?
  created_at    DateTime    @default(now()) @db.Timestamptz
  worklog       worklog     @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  remittance    remittance? @relation(fields: [remittance_id], references: [id])

  @@index([parent_id])
  @@index([created_at, type])
  @@index([start_time])
  @@index([applied_at])
  @@index([remittance_id])
}

model remittance {
  id           Int       @id @default(autoincrement())
  user_id      String
  period_start DateTime  @db.Date
  period_end   DateTime  @db.Date
  amount       Decimal   @db.Decimal(10, 2)
  status       String    @default("PENDING")
  worklog_ids  Json      @default("[]")
  created_at   DateTime  @default(now()) @db.Timestamptz
  worklogs     worklog[]
  records      record[]

  @@unique([user_id, period_start, period_end])
  @@index([user_id])
  @@index([created_at])
}
