{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2023",

    "moduleResolution": "nodenext",

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "strict": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "./dist"
  }
}